# Career Compass AI Backend Environment Variables

# The port the backend server should listen on (defaults to 5000)
PORT=5000

# MongoDB Connection String (Atlas starting with mongodb+srv:// or Local MongoDB URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/career-compass-ai
MONGO_URI=mongodb://localhost:27017/career-compass-ai

# Google Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Google Gemini Model choice (defaults to gemini-1.5-flash for production stability)
GEMINI_MODEL=gemini-1.5-flash

# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET=your_jwt_secret_key_here

# The URL of the frontend application, used to restrict CORS access (e.g. https://career-compass.vercel.app)
CLIENT_URL=http://localhost:5173
